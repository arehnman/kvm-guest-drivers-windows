  <Target Name="UpdateInxFile" BeforeTargets="PrepareForBuild" Condition="('$(Platform)' == 'Win32' AND Exists('$(MESA_PREFIX_x86)\bin\viogpu_d3d10.dll')) OR ('$(Platform)' == 'x64' AND Exists('$(MESA_PREFIX_x64)\bin\viogpu_d3d10.dll')) OR ('$(Platform)' == 'ARM64' AND Exists('$(MESA_PREFIX_ARM64)\bin\viogpu_d3d10.dll'))">
    <Message Text="Updating driver package INX files" Importance="High" />
    <ItemGroup>
      <TargetInxFiles Condition="'$(Platform)' == 'x64' AND Exists('$(MESA_PREFIX_x64)\bin\viogpu_d3d10.dll') AND Exists('$(MESA_PREFIX_x86)\bin\viogpu_d3d10.dll')" Include="viogpu3d_x64_wow64.inx" />
      <TargetInxFiles Condition="'$(Platform)' == 'x64' AND Exists('$(MESA_PREFIX_x64)\bin\viogpu_d3d10.dll') AND !Exists('$(MESA_PREFIX_x86)\bin\viogpu_d3d10.dll')" Include="viogpu3d_x64.inx" />
      <TargetInxFiles Condition="'$(Platform)' == 'ARM64' AND Exists('$(MESA_PREFIX_ARM64)\bin\viogpu_d3d10.dll') AND Exists('$(MESA_PREFIX_x86)\bin\viogpu_d3d10.dll')" Include="viogpu3d_arm64_wow64.inx" />
      <TargetInxFiles Condition="'$(Platform)' == 'ARM64' AND Exists('$(MESA_PREFIX_ARM64)\bin\viogpu_d3d10.dll') AND !Exists('$(MESA_PREFIX_x86)\bin\viogpu_d3d10.dll')" Include="viogpu3d_arm64.inx" />
      <TargetInxFiles Condition="'$(Platform)' == 'Win32'" Include="viogpu3d_x86.inx" />
    </ItemGroup>
    <Copy 
      SourceFiles="@(TargetInxFiles)"
      DestinationFiles="@(TargetInxFiles->'viogpu3d.inx')"
      SkipUnchangedFiles="true"
      OverwriteReadOnlyFiles="true"
    />
  </Target>
