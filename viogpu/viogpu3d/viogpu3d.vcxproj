    <Exec Condition="'$(Platform)' == 'ARM64' AND Exists('$(MESA_PREFIX_ARM64)\bin\viogpu_d3d10.dll')" Command="%25SystemRoot%25\System32\WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;$(ProjectDir)tools\update_icd_jsons.ps1&quot; -MesaPrefix &quot;$(MESA_PREFIX_ARM64)&quot; -MesaArch aarch64" />
    <Exec Condition="Exists('$(MESA_PREFIX_x86)\bin\viogpu_d3d10.dll')" Command="%25SystemRoot%25\System32\WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;$(ProjectDir)tools\update_icd_jsons.ps1&quot; -MesaPrefix &quot;$(MESA_PREFIX_x86)&quot; -MesaArch x86" />
